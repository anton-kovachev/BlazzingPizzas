@inject HttpClient httpClient
@inject NavigationManager navigationManager

@page "/"

<h1>Blazing Pizzas</h1>
@page "/"

<div class="main">
    <h1>Blazzing Pizzas</h1>
    <h1>My favourite Pizza is:</h1>

    <p>
        Enter your favourite Pizza:
        <input @bind="favouritePizza" /> 
    </p>

    <p>
        Your email address is:
        <input @bind="customerEmail" />
    </p>

    @if (specials == null)
    {
        <h2>No Specials</h2>
    }
    else
    {
        <ul class="pizza-cards">
            @foreach (var special in specials)
            {
                <li style="background-image: url('@special.ImageUrl')" @onclick="() => ShowConfigurablePizzaDialog(special)">
                    <div class="pizza-info">
                        <span>@special.Name</span>
                        @special.Description
                        <span class="prce">@special.GetFormattedBasePrice()</span>
                    </div>
                </li>
            }
        </ul>
    }
    
    @if(showConfigureDialog)
    {
        <ConfigurePizzaDialog Pizza="configurablePizza" />

    }
</div>

@code {
    Pizza configurablePizza;
    bool showConfigureDialog;
    List<PizzaSpecial> specials = new();
    public string customerEmail { get; set; } = "john.doe@contoso.com";
    public string favouritePizza { get; set; } = "Margarita";

    void ShowConfigurablePizzaDialog(PizzaSpecial pizzaSpecial)
    {
        configurablePizza = new Pizza
        {
            Special = pizzaSpecial,
            SpecialId = pizzaSpecial.Id,
            Size = Pizza.DefaultSize
        };

        showConfigureDialog = true;
    }

    protected override async Task OnInitializedAsync()
    {
        this.specials = await httpClient.GetFromJsonAsync<List<PizzaSpecial>>(navigationManager.BaseUri + "specials");

        //specials.AddRange(new List<PizzaSpecial>
